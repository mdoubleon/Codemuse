# CodeMuse local model settings.
# Copy this file to .env and fill in your real key.
# .env is ignored by git and loaded automatically by scripts/run_server.py.

CODEMUSE_API_KEY=your_api_key_here
CODEMUSE_BASE_URL=https://api.openai.com/v1
CODEMUSE_MODEL=gpt-4o-mini

# Optional: override provider name. Usually leave this unset.
# CODEMUSE_PROVIDER=openai_compatible

# Optional: if you want to store the key in another variable.
# CODEMUSE_API_KEY_ENV=OPENAI_API_KEY
